<div id="login-screen"><div class="login-box"><div class="login-top"><div class="login-logo"><img src="logo.png" alt="Rocha Reboques" style="height:80px;width:auto;object-fit:contain;display:block;mix-blend-mode:lighten"></div><div class="login-welcome" style="margin-top:10px">Bem-vindo</div><div class="login-welcome-sub">Acesse com suas credenciais para continuar</div></div><div class="login-body"><div class="login-fg"><div class="login-label">Usuário</div><div class="login-input-wrap"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> <input class="login-inp" id="login-user" placeholder="Digite seu usuário" autocomplete="username" onkeydown='"Enter"===event.key&&document.getElementById("login-pass").focus()'></div></div><div class="login-fg"><div class="login-label">Senha</div><div class="login-input-wrap"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg> <input class="login-inp" type="password" id="login-pass" placeholder="Digite sua senha" autocomplete="current-password" onkeydown='"Enter"===event.key&&fazerLogin()'> <button class="login-eye" onclick="toggleSenhaVis()" id="login-eye-btn" title="Mostrar/ocultar senha"><svg id="eye-icon" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button></div></div><div class="login-error" id="login-error"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg> <span id="login-error-msg">Usuário ou senha incorretos.</span></div><button class="login-btn" onclick="fazerLogin()" id="login-btn"><svg viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg> Entrar</button></div><div class="login-footer">Pelotas – RS &nbsp;·&nbsp; v1.0</div></div></div>