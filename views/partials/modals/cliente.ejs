<div class="modal-overlay" id="modal-cliente" onclick='fecharSeOverlay(event,"modal-cliente")'><div class="modal"><div class="modal-hd"><div class="modal-title" id="modal-cliente-titulo">Novo Cliente</div><div class="modal-close" onclick='fecharModal("modal-cliente")'><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div></div><div class="modal-body"><input type="hidden" id="cl-id"><div class="form-row c2"><div class="fg"><label>Nome Completo *</label> <input class="inp" id="cl-nome" placeholder="Nome do cliente"></div><div class="fg"><label>CPF / CNPJ</label> <input class="inp" id="cl-cpf" placeholder="000.000.000-00"></div></div><div class="form-row c2"><div class="fg"><label>Telefone / WhatsApp *</label> <input class="inp" id="cl-tel" placeholder="(53) 9 9999-9999"></div><div class="fg"><label>RG</label> <input class="inp" id="cl-rg" placeholder="00.000.000-0"></div></div><div class="form-row c2"><div class="fg"><label>CEP</label> <input class="inp" id="cl-cep" placeholder="00000-000" maxlength="9" onblur="buscarCEP()" onkeydown="if(event.key==='Enter'){event.preventDefault();buscarCEP();}"></div><div class="fg"><label>Cidade</label> <input class="inp" id="cl-cidade" placeholder="Pelotas"></div></div><div class="form-row"><div class="fg span2"><label>Endereço</label> <input class="inp" id="cl-end" placeholder="Rua, número, bairro"></div></div><div class="form-row c2"><div class="fg"><label>Nº CNH</label> <input class="inp" id="cl-cnh" placeholder="Número da habilitação"></div><div class="fg"><label>Categoria CNH</label> <select class="inp" id="cl-cat"><option value="">—<option value="A">A<option value="B">B<option value="AB">AB<option value="C">C<option value="D">D<option value="E">E</select></div></div><div class="form-row c2"><div class="fg"><label>Renavan</label> <input class="inp" id="cl-renavan" placeholder="Código Renavan do veículo"></div><div class="fg"><label>Placa do Veículo</label> <input class="inp" id="cl-placa-veiculo" placeholder="Ex: ABC-1234"></div></div><div class="form-row"><div class="fg span2"><label>Observações</label> <textarea class="inp" id="cl-obs" placeholder="Informações adicionais..."></textarea></div></div></div><div class="modal-ft"><button class="btn btn-ghost" onclick='fecharModal("modal-cliente")'>Cancelar</button> <button class="btn btn-primary" onclick="salvarCliente()"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Salvar Cliente</button></div></div></div>