<div class="modal-overlay" id="modal-manutencao" onclick='fecharSeOverlay(event,"modal-manutencao")'><div class="modal"><div class="modal-hd"><div class="modal-title" id="modal-manutencao-titulo">Nova Manutenção</div><div class="modal-close" onclick='fecharModal("modal-manutencao")'><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div></div><div class="modal-body"><input type="hidden" id="mn-id"><div class="form-row"><div class="fg span2"><label>Reboque *</label><select class="inp" id="mn-reboque-sel"><option value="">Selecionar reboque...</select></div></div><div class="form-row c2"><div class="fg"><label>Tipo de Manutenção *</label><input class="inp" id="mn-tipo" placeholder="Ex: Troca de óleo, Freios..."></div><div class="fg"><label>Custo (R$)</label><input class="inp" type="number" id="mn-custo" value="0"></div></div><div class="form-row"><div class="fg span2"><label>Observações</label><textarea class="inp" id="mn-obs" placeholder="Detalhes do serviço, peças trocadas..."></textarea></div></div></div><div class="modal-ft"><button class="btn btn-ghost" onclick='fecharModal("modal-manutencao")'>Cancelar</button><button class="btn btn-primary" onclick="salvarManutencao()"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Salvar</button></div></div></div>