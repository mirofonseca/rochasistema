<div class="modal-overlay" id="modal-reserva" onclick='fecharSeOverlay(event,"modal-reserva")'><div class="modal"><div class="modal-hd"><div class="modal-title">Nova Reserva</div><div class="modal-close" onclick='fecharModal("modal-reserva")'><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div></div><div class="modal-body"><input type="hidden" id="res-reboque-id"><div class="form-row"><div class="fg span2"><label>Reboque</label> <input class="inp" id="res-reboque-nome" readonly style="background:var(--bg);font-weight:700;color:var(--org)"></div></div><div class="form-row"><div class="fg span2"><label>Buscar Cliente por CPF</label> <input class="inp" id="res-cpf-busca" placeholder="Digite o CPF e pressione Enter" maxlength="14" onblur="buscarClienteParaReserva()" onkeydown="if(event.key==='Enter'){event.preventDefault();buscarClienteParaReserva();}"></div></div><div class="form-row"><div class="fg span2"><label>Cliente *</label> <select class="inp" id="res-cliente-sel"><option value="">Selecionar cliente...</select></div></div><div class="form-row c2"><div class="fg"><label>Data Início *</label> <input class="inp" type="date" id="res-inicio"></div><div class="fg"><label>Data Fim *</label> <input class="inp" type="date" id="res-fim"></div></div><div class="form-row"><div class="fg span2"><label>Observações</label> <textarea class="inp" id="res-obs" placeholder="Detalhes da reserva..."></textarea></div></div></div><div class="modal-ft"><button class="btn btn-ghost" onclick='fecharModal("modal-reserva")'>Cancelar</button><button class="btn btn-primary" onclick="salvarReserva()"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Reservar</button></div></div></div>
