<div class="modal-overlay" id="modal-aluguel" onclick='fecharSeOverlay(event,"modal-aluguel")'><div class="modal"><div class="modal-hd"><div class="modal-title" id="modal-aluguel-titulo">Novo Aluguel</div><div class="modal-close" onclick='fecharModal("modal-aluguel")'><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div></div><div class="modal-body"><input type="hidden" id="al-id"><div class="form-row"><div class="fg span2"><label>Buscar Cliente por CPF</label> <input class="inp" id="al-cpf-busca" placeholder="Digite o CPF e pressione Enter" maxlength="14" onblur="buscarClientePorCPF()" onkeydown="if(event.key==='Enter'){event.preventDefault();buscarClientePorCPF();}"></div></div><div class="form-row c2"><div class="fg"><label>Cliente *</label> <select class="inp" id="al-cliente-sel"><option value="">Selecionar cliente...</select></div><div class="fg"><label>Reboque *</label> <select class="inp" id="al-reboque-sel"><option value="">Selecionar reboque...</select></div></div><div class="form-row c2"><div class="fg"><label>Data de Saída *</label><input class="inp" type="date" id="al-saida" onchange="calcAluguel()"></div><div class="fg"><label>Horário de Saída *</label><input class="inp" type="time" id="al-hora-saida" value="08:00" onchange="calcAluguel()"></div></div><div class="form-row c2"><div class="fg"><label>Data de Devolução *</label><input class="inp" type="date" id="al-devolucao" onchange="calcAluguel()"></div><div class="fg"><label>Horário de Devolução *</label><input class="inp" type="time" id="al-hora-devolucao" value="08:00" onchange="calcAluguel()"></div></div><div class="form-row c3"><div class="fg"><label>Valor/Dia (R$)</label> <input class="inp" type="number" id="al-diaria" value="70" oninput="calcAluguel()"></div><div class="fg"><label>Nº de Dias</label> <input class="inp" type="number" id="al-dias" readonly="readonly"></div><div class="fg"><label>Total (R$)</label> <input class="inp" type="number" id="al-total" readonly="readonly" style="font-weight:700;color:var(--org)"></div></div><div class="form-row c2"><div class="fg"><label>Pagamento</label> <select class="inp" id="al-pagamento"><option value="pendente">Pendente<option value="parcial">Parcial<option value="pago">Pago</select></div><div class="fg"><label>Status</label> <select class="inp" id="al-status"><option value="ativo">Ativo<option value="encerrado">Encerrado</select></div></div><div class="form-row"><div class="fg span2"><label>Observações</label> <textarea class="inp" id="al-obs" placeholder="Condições do reboque na saída, observações..."></textarea></div></div></div><div class="modal-ft"><button class="btn btn-ghost" onclick='fecharModal("modal-aluguel")'>Cancelar</button> <button class="btn btn-primary" onclick="salvarAluguel()"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Salvar Aluguel</button></div></div></div>