<div class="modal-overlay" id="modal-reboque" onclick='fecharSeOverlay(event,"modal-reboque")'><div class="modal"><div class="modal-hd"><div class="modal-title" id="modal-reboque-titulo">Novo Reboque</div><div class="modal-close" onclick='fecharModal("modal-reboque")'><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div></div><div class="modal-body"><input type="hidden" id="rb-id"><div class="form-row c2"><div class="fg"><label>Nome / Identificação *</label> <input class="inp" id="rb-nome" placeholder="Ex: Reboque Aberto 01"></div><div class="fg"><label>Tipo *</label> <select class="inp" id="rb-tipo"><option value="Aberto">Aberto<option value="Fechado">Fechado<option value="Plataforma">Plataforma<option value="Carga Animal">Carga Animal<option value="Asa Delta">Asa Delta<option value="Personalizado">Personalizado</select></div></div><div class="form-row c2"><div class="fg"><label>Placa</label> <input class="inp" id="rb-placa" placeholder="ABC-1234"></div><div class="fg"><label>Capacidade (kg)</label> <input class="inp" type="number" id="rb-cap" placeholder="500"></div></div><div class="form-row c2"><div class="fg"><label>Valor / Dia (R$) *</label> <input class="inp" type="number" id="rb-diaria" value="70"></div><div class="fg"><label>Status</label> <select class="inp" id="rb-status"><option value="disponivel">Disponível<option value="manutencao">Manutenção</select></div></div><div class="form-row"><div class="fg span2"><label>Observações</label> <textarea class="inp" id="rb-obs" placeholder="Estado de conservação, características especiais..."></textarea></div></div></div><div class="modal-ft"><button class="btn btn-ghost" onclick='fecharModal("modal-reboque")'>Cancelar</button> <button class="btn btn-primary" onclick="salvarReboque()"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Salvar Reboque</button></div></div></div>